# Production Environment Variables
# Copy this to .env.prod and fill in your real values
# NEVER commit .env.prod to git!

# ========================================
# MONGODB (for production docker-compose)
# ========================================
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ========================================
# JWT SECRETS (generate strong random strings!)
# Run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ========================================
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS

# ========================================
# URLS (update when you know your server IP or domain)
# ========================================
FRONTEND_URL=http://YOUR_SERVER_IP_OR_DOMAIN
NEXT_PUBLIC_API_BASE_URL=http://YOUR_SERVER_IP_OR_DOMAIN:5000/api/v1
NEXT_PUBLIC_APP_URL=http://YOUR_SERVER_IP_OR_DOMAIN

# ========================================
# EMAIL (Gmail example - use App Password)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-gmail-app-password
EMAIL_FROM=noreply@kalimhs.com
EMAIL_FROM_NAME=Kali MHS
ADMIN_EMAILS=admin@kalimhs.com
