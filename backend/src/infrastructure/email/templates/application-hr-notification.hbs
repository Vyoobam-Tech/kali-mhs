<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Job Application</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            line-height: 1.6;
            color: #333;
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
        }

        .header {
            background: #7c3aed;
            color: white;
            padding: 20px;
            text-align: center;
            border-radius: 8px 8px 0 0;
        }

        .content {
            background: #f9fafb;
            padding: 30px;
            border-radius: 0 0 8px 8px;
        }

        .alert-badge {
            background: #faf5ff;
            color: #7c3aed;
            padding: 10px 20px;
            border-radius: 6px;
            display: inline-block;
            font-weight: bold;
            margin: 15px 0;
        }

        .applicant-card {
            background: white;
            padding: 20px;
            border-radius: 6px;
            margin: 20px 0;
        }

        .applicant-name {
            font-size: 20px;
            font-weight: bold;
            color: #111827;
            margin-bottom: 10px;
        }

        .contact-info {
            color: #6b7280;
            margin: 5px 0;
        }

        .cta-button {
            display: inline-block;
            background: #7c3aed;
            color: white;
            padding: 12px 30px;
            text-decoration: none;
            border-radius: 6px;
            margin: 20px 0;
        }

        .footer {
            text-align: center;
            margin-top: 30px;
            color: #6b7280;
            font-size: 14px;
        }
    </style>
</head>

<body>
    <div class="header">
        <h1>👤 New Job Application</h1>
    </div>
    <div class="content">
        <div class="alert-badge">NEW CANDIDATE</div>

        <h2>{{jobTitle}}</h2>

        <div class="applicant-card">
            <div class="applicant-name">{{applicantName}}</div>
            <div class="contact-info">📧 {{applicantEmail}}</div>
            <div class="contact-info">📱 {{applicantPhone}}</div>
        </div>

        <p><strong>Application Submitted:</strong> {{submittedAt}}</p>

        {{#if resumeUrl}}
        <p><strong>Resume:</strong> <a href="{{resumeUrl}}">Download Resume</a></p>
        {{/if}}

        <a href="{{viewUrl}}" class="cta-button">Review Application →</a>

        <p style="margin-top: 30px; font-size: 14px; color: #6b7280;">
            Please review this application and update the candidate status in the ATS.
        </p>
    </div>
    <div class="footer">
        <p>© 2026 Kali MHS HR System</p>
    </div>
</body>

</html>